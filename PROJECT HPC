        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Time intervals\n",
        "time = [1, 2, 3, 4, 5]\n",
        "\n",
        "# Serial traffic (slow growth)\n",
        "serial_traffic = [2, 4, 6, 8, 10]\n",
        "\n",
        "# Parallel traffic (fast growth)\n",
        "parallel_traffic = [3, 7, 12, 18, 25]\n",
        "\n",
        "# Plot both graphs in one figure\n",
        "plt.plot(time, serial_traffic, marker='o', label='Serial Traffic')\n",
        "plt.plot(time, parallel_traffic, marker='o', label='Parallel Traffic')\n",
        "\n",
        "# Adding labels and title\n",
        "plt.xlabel(\"Time\")\n",
        "plt.ylabel(\"Number of Vehicles\")\n",
        "plt.title(\"Serial vs Parallel Traffic Flow\")\n",
        "\n",
        "plt.legend()\n",
        "\n",
        "# Show grid (optional but looks better)\n",
        "plt.grid()\n",
        "\n",
        "# Display graph\n",
        "plt.show()"
      ],
